# Configurações do Ambiente
DEBUG=False
SECRET_KEY=insira_uma_chave_secreta_longa_e_aleatoria_aqui
ALLOWED_HOSTS=saldon.com,www.saldon.com

# Chaves de API
ABACATEPAY_API_KEY=sua_api_key_do_abacatepay_aqui

# Banco de Dados (Supabase / PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# CORS (Frontends autorizados a acessar a API separados por vírgula)
CORS_ALLOWED_ORIGINS=https://saldon.com,https://app.saldon.com
